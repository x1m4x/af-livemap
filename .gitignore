# Runtime-данные сервера (скан, точки, лифты, порталы, тележки, заметки) —
# генерируются при игре, у каждого свои.
data/

# Файлы, которые пишет мод (появляются в папке игры, не в репозитории)
mod/livemap.json
mod/lidar.json

# Картинки секторов — скриншоты со сторонних ресурсов (TechRaptor и т.п.).
# Не распространяются с проектом; каждый добавляет свои (см. README).
maps/*.webp
maps/*.png
maps/*.jpg
maps/maps.json

